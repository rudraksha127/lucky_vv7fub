# ─── AlgoZen Server Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# If MONGODB_URI is omitted, in-memory MongoDB (mongodb-memory-server) is used automatically.

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (optional — leave blank for in-memory dev mode)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/algozen

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Clerk (for optional Clerk/OAuth integration)
# CLERK_SECRET_KEY=sk_test_...

# AI Services (at least one required for AlgoGuru features)
GROQ_API_KEY=gsk_your-groq-api-key
# OPENAI_API_KEY=sk-your-openai-api-key

# Admin
ADMIN_KEY=algozen-admin-secret-key

# Judge0 (code execution engine)
# JUDGE0_API_URL=http://localhost:2358
# JUDGE0_API_KEY=
