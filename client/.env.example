# ─── AlgoZen Client Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# Vite requires the VITE_ prefix on all exposed variables.

# Backend API URL (REQUIRED)
VITE_API_URL=http://localhost:5000

# WebSocket URL (same as API URL if using same server)
VITE_SOCKET_URL=http://localhost:5000

# Clerk publishable key (optional — for OAuth/Social login)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
